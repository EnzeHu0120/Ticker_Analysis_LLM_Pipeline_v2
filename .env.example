# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# Primary (Gemini, original pipeline)
GEMINI_API_KEY=

# Optional: temporary OpenAI backend
OPENAI_API_KEY=
OPENAI_BASE_URL=https://cbsai.business.columbia.edu/api/v1

# Backend selection (defaults used if not set):
# ANALYSIS_DATE=2025-02-28
# LLM_BACKEND=gemini        # options: gemini | gemini-vertex | openai
# GEMINI_MODEL=gemini-3-flash-preview
# OPENAI_MODEL=gpt-4o-mini
# REPORT_MODE=lean           # options: lean | full
# ENABLE_NEWS=false          # default recommended for scan cost/performance
# NEWS_LOOKBACK_DAYS=10      # effective range is clamped to 7..14
# NEWS_LIMIT_PER_SOURCE=8

# Vertex AI (only used when LLM_BACKEND=gemini-vertex)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# Optional: news / catalyst (FMP, Finnhub). Leave empty if not used.
FMP_API_KEY=
FINNHUB_API_KEY=
